# StreamFeature Environment Variables
# Copy this to .env and fill in your values

# ── AI Dashboard (Required for AI features) ──────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Kafka ──────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092,localhost:9093,localhost:9094
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Redis Cluster ──────────────────────────────────────────────────
REDIS_ADDRS=localhost:7001,localhost:7002,localhost:7003,localhost:7004,localhost:7005,localhost:7006
REDIS_PASSWORD=

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DSN=postgres://featurestore:featurestore123@localhost:5432/featurestore?sslmode=disable

# ── MinIO / S3 ────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=feature-offline-store

# ── Flink ─────────────────────────────────────────────────────────
FLINK_REST_URL=http://localhost:8082
FLINK_CHECKPOINT_DIR=s3a://flink-checkpoints/checkpoints

# ── Observability ─────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
JAEGER_ENDPOINT=http://localhost:4318

# ── API Server ────────────────────────────────────────────────────
GRPC_PORT=50051
METRICS_PORT=2112
LOCAL_CACHE_SIZE=10000
LOCAL_CACHE_TTL=1s
